# ──────────────────────────────────────────────────────────
# Variables de entorno — HelloWorld App
# Copia este archivo a .env y ajusta los valores
# ──────────────────────────────────────────────────────────

# Puerto del backend (interno)
PORT=3000

# Puerto expuesto al host
APP_PORT=80

# ─── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=helloworld
POSTGRES_USER=hwuser
# CAMBIAR EN PRODUCCIÓN — mínimo 16 caracteres aleatorios
POSTGRES_PASSWORD=changeme_in_production

# ─── JWT local (registro / login con email+contraseña) ────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=1h

# ─── Okta OIDC ────────────────────────────────────────────
# Pasos para obtener estos valores:
#   1. Ir a https://developer.okta.com  → Create Free Account
#   2. Applications → Create App Integration → OIDC → SPA
#   3. Nombre: HelloWorld, Redirect URI: http://localhost/login/callback
#   4. Copiar "Issuer" (ej: https://dev-XXXXXXXX.okta.com/oauth2/default)
#      y "Client ID" desde la sección de la aplicación creada
OKTA_ISSUER=https://dev-XXXXXXXX.okta.com/oauth2/default
OKTA_CLIENT_ID=your_okta_client_id_here

# URL del frontend (usada por el backend para CORS)
FRONTEND_URL=http://localhost
